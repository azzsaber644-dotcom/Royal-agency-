        function closeSimModal() {
            const modal = document.getElementById('simModal');
            modal.style.display = 'none';
        }

        function openCodeModal(event) {
            if (event) event.preventDefault();
            const modal = document.getElementById('codeModal');
            const timer = document.getElementById('codeTimer');
            
            let countdown = 5;
            timer.textContent = countdown;
            modal.style.display = 'flex';
            
            const interval = setInterval(() => {
                countdown--;
                timer.textContent = countdown;
                
                if (countdown <= 0) {
                    clearInterval(interval);
                    closeCodeModal();
                }
            }, 1000);
        }

        function copyCodeFromModal() {
            navigator.clipboard.writeText('YZDPCB').then(() => {
                const btn = document.getElementById('copyCodeBtn');
                btn.textContent = '✅ تم النسخ!';
                setTimeout(() => {
                    btn.textContent = '📋 نسخ الكود';
                }, 2500);
            });
        }

        function createGemFloat(x, y) {
            const gem = document.createElement('div');
            gem.className = 'gem-float';
            gem.textContent = '💎';
            gem.style.left = x + 'px';
            gem.style.top = y + 'px';
            document.body.appendChild(gem);
            
            setTimeout(() => gem.remove(), 1500);
        }

        function startSimulation() {
            const simMessages = document.getElementById('simMessages');
            const simReplies = document.getElementById('simRepliesContainer');
            const simGift = document.getElementById('simGiftContainer');
            const simFinal = document.getElementById('simFinalContainer');
            const simAlert = document.getElementById('simAlertArea');
            
            simMessages.innerHTML = '';
            simReplies.innerHTML = '';
            simGift.style.display = 'none';
            simFinal.style.display = 'none';
            simAlert.innerHTML = '';

            function addMessage(text, isUser = false) {
                const div = document.createElement('div');
                div.className = `sim-message ${isUser ? 'user-msg' : 'bot-msg'}`;
                div.textContent = text;
                simMessages.appendChild(div);
                simMessages.scrollTop = simMessages.scrollHeight;
            }

            function addGems(amount) {
                const div = document.createElement('div');
                div.style.textAlign = 'center';
                div.style.color = '#fbbf24';
                div.style.fontWeight = '900';
                div.style.animation = 'slideIn 0.3s ease';
                div.innerHTML = `💎 +${amount} ماسة`;
                simMessages.appendChild(div);
                
                const rect = simMessages.getBoundingClientRect();
                createGemFloat(rect.left + rect.width / 2, rect.top);
                
                simMessages.scrollTop = simMessages.scrollHeight;
            }

            function showAlert(type, text) {
                simAlert.innerHTML = '';
                const alertDiv = document.createElement('div');
                alertDiv.className = `sim-alert ${type}`;
                let icon = '⚠️';
                if (type === 'success') icon = '✅';
                else if (type === 'warning') icon = '⚡';
                alertDiv.innerHTML = `${icon} ${text}`;
                simAlert.appendChild(alertDiv);
            }

            function showReplies(replies, callback) {
                simReplies.innerHTML = '';
                replies.forEach((reply, index) => {
                    const btn = document.createElement('button');
                    btn.className = 'sim-reply-btn';
                    btn.textContent = reply;
                    btn.style.animationDelay = `${index * 0.15}s`;
                    btn.addEventListener('click', () => {
                        simReplies.innerHTML = '';
                        callback(reply);
                    });
                    simReplies.appendChild(btn);
                });
            }

            setTimeout(() => {
                addMessage('👤 المستخدم: السلام عليكم ورحمة الله');
                
                setTimeout(() => {
                    showReplies(['وعليكم السلام ورحمة الله وبركاته'], (reply) => {
                        addMessage(`👩 المضيفة: ${reply}`, true);
                        addGems(15);
                        
                        setTimeout(() => {
                            addMessage('👤 المستخدم: أنا جديد في التطبيق هل تساعديني؟');
                            showReplies(['بكل سرور يا حبيبتي! كيفك انتي؟'], (reply2) => {
                                addMessage(`👩 المضيفة: ${reply2}`, true);
                                addGems(25);
                                
                                setTimeout(() => {
                                    addMessage('👤 المستخدم: أنا تمام الحمد لله، شو اسمك؟');
                                    showReplies(['اسمي ياسمين وأنا هنا لمساعدتك دايماً'], (reply3) => {
                                        addMessage(`👩 المضيفة: ${reply3}`, true);
                                        addGems(30);
                                        
                                        setTimeout(() => {
                                            addMessage('👤 المستخدم: حلو يا ياسمين.... بدك رقمي الشخصي؟');
                                            showAlert('warning', '⚠️ تنبيه: طلب معلومات شخصية! حظري!');
                                            showReplies(['حظر وإبلاغ الإدارة فوراً'], (reply4) => {
                                                addMessage(`👩 المضيفة: تم حظر المستخدم وتقديم بلاغ`, true);
                                                addGems(15000);
                                                
                                                setTimeout(() => {
                                                    simGift.style.display = 'block';
                                                    setTimeout(() => {
                                                        simFinal.style.display = 'block';
                                                    }, 1500);
                                                }, 500);
                                            });
                                        }, 500);
                                    });
                                }, 600);
                            });
                        }, 600);
                    });
                }, 800);
            }, 200);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // === الأسئلة الشائعة ===
            document.querySelectorAll('.faq-q').forEach(button => {
                button.addEventListener('click', function() {
                    const answer = this.nextElementSibling;
                    const isActive = answer.classList.contains('active');
                    
                    document.querySelectorAll('.faq-a').forEach(a => {
                        a.classList.remove('active');
                        a.style.maxHeight = '0';
                    });
                    
                    if (!isActive) {
                        answer.classList.add('active');
                        answer.style.maxHeight = answer.scrollHeight + 'px';
                    }
                });
            });

            // === الشرح المفصل ===
            document.getElementById('detailedExplanationBtn').addEventListener('click', () => {
                const modal = document.getElementById('modal');
                const body = document.getElementById('modalBody');
                
                body.innerHTML = `
                    <p style="margin-bottom: 15px;">🙋‍♀️ ازيك يا قمر! 💖 الشغل معانا بسيط جداً على منصة Kachi</p>
                    <p style="margin-bottom: 10px;">💸 <strong>مجاني 100%</strong> – ولا مليم هيتدفع</p>
                    <p style="margin-bottom: 10px;">💰 <strong>سحب ذاتي</strong> – أقل حد 1 دولار (6000 ماسة)</p>
                    <p style="margin-bottom: 10px;">🔞 <strong>السن</strong> – لازم تكوني 18 سنة فأكثر</p>
                    <p style="margin-bottom: 10px;">💬 <strong>الشغل</strong> – رسايل ومكالمات، كل رد بيديك ماسات</p>
                    <p style="margin-bottom: 10px;">📈 <strong>المستويات</strong> – كل ما ترتقي، سعر الرسالة والمكالمة بيزيد</p>
                    <p style="margin-bottom: 10px;">🛡️ <strong>الأمان</strong> – تقدري تحظري أي شخص قليل أدب</p>
                    <p>💎 <strong>المكاسب</strong> – كل 6000 ماسة = 1 دولار</p>
                `;
                
                modal.style.display = 'flex';
            });

            // === المحاكاة ===
            document.getElementById('simulateBtn')?.addEventListener('click', () => {
                const modal = document.getElementById('simModal');
                modal.style.display = 'flex';
                startSimulation();
            });

            // === إغلاق المودالات ===
            document.getElementById('codeModal').addEventListener('click', function(e) {
                if (e.target === this) closeCodeModal();
            });

            document.getElementById('modal').addEventListener('click', function(e) {
                if (e.target === this) closeModal();
            });

            document.getElementById('simModal').addEventListener('click', function(e) {
                if (e.target === this) closeSimModal();
            });
        });

        // === تبديل الأزرار العائمة ===
        setInterval(() => {
            const btnSim = document.getElementById('simulateBtn');
            const btnTelegram = document.getElementById('btnTelegram');
            
            if (btnSim && btnTelegram) {
                btnSim.classList.toggle('hidden-float');
                btnTelegram.classList.toggle('hidden-float');
            }
        }, 10000);
    </script>

    <!-- === الأزرار العائمة === -->
    <div class="floating-actions">
        <button id="simulateBtn" class="btn-pulse-fixed">🎬 اختبري الآن</button>
        <button id="btnTelegram" class="btn-telegram hidden-float" onclick="window.open('https://t.me/yourusername')">
            <span style="font-size: 1.2rem;">✈️</span>
            <span style="font-size: 0.5rem;">تيلجرام</span>
        </button>
    </div>
</body>
</html>
